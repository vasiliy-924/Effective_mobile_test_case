# Copy to .env for local runs (optional; compose sets vars for Docker).

DATABASE_URL=postgres://app:app@localhost:5432/subscriptions?sslmode=disable
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text
MIGRATIONS_PATH=file://migrations
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_WAIT=1s

# Leave unset to load ./config.yaml; set to empty in shell to skip YAML: export CONFIG_YAML=
# CONFIG_YAML=config.yaml
